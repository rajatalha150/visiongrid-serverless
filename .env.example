# Backend Environment Variables (for Vercel deployment)

# Admin panel password
ADMIN_PASSWORD=admin123

# Chatbot (Ollama Cloud) — server-side only; set this in Vercel project env vars.
# Without it the chatbot falls back to the keyword responder.
OLLAMA_API_KEY=
# Optional overrides (defaults shown):
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_CHAT_MODEL=gemma4:31b-cloud

# Environment
NODE_ENV=production